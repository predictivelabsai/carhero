    "components": {
        "schemas": {
            "AgentOut": {
                "properties": {
                    "slug": {
                        "type": "string",
                        "title": "Slug"
                    },
                    "name": {
                        "type": "string",
                        "title": "Name"
                    },
                    "category": {
                        "type": "string",
                        "title": "Category"
                    },
                    "icon": {
                        "type": "string",
                        "title": "Icon"
                    },
                    "one_liner": {
                        "type": "string",
                        "title": "One Liner"
                    },
                    "prefix": {
                        "type": "string",
                        "title": "Prefix"
                    },
                    "example_prompts": {
                        "items": {
                            "type": "string"
                        },
                        "type": "array",
                        "title": "Example Prompts"
                    }
                },
                "type": "object",
                "required": [
                    "slug",
                    "name",
                    "category",
                    "icon",
                    "one_liner",
                    "prefix",
                    "example_prompts"
                ],
                "title": "AgentOut"
            },
            "AuthResponse": {
                "properties": {
                    "token": {
                        "type": "string",
                        "title": "Token"
                    },
                    "email": {
                        "type": "string",
                        "title": "Email"
                    },
                    "name": {
                        "type": "string",
                        "title": "Name",
                        "default": ""
                    },
                    "user_id": {
                        "type": "integer",
                        "title": "User Id"
                    }
                },
                "type": "object",
                "required": [
                    "token",
                    "email",
                    "user_id"
                ],
                "title": "AuthResponse"
            },
            "ChatRequest": {
                "properties": {
                    "message": {
                        "type": "string",
                        "maxLength": 4000,
                        "minLength": 1,
                        "title": "Message"
                    },
                    "session_id": {
                        "anyOf": [
                            {
                                "type": "integer"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Session Id"
                    },
                    "lang": {
                        "type": "string",
                        "title": "Lang",
                        "default": "en"
                    }
                },
                "type": "object",
                "required": [
                    "message"
                ],
                "title": "ChatRequest"
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "LoginRequest": {
                "properties": {
                    "email": {
                        "type": "string",
                        "minLength": 3,
                        "title": "Email"
                    },
                    "password": {
                        "type": "string",
                        "minLength": 1,
                        "title": "Password"
                    }
                },
                "type": "object",
                "required": [
                    "email",
                    "password"
                ],
                "title": "LoginRequest"
            },
            "MessageOut": {
                "properties": {
                    "role": {
                        "type": "string",
                        "title": "Role"
                    },
                    "content": {
                        "type": "string",
                        "title": "Content"
                    },
                    "agent_slug": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Agent Slug"
                    }
                },
                "type": "object",
                "required": [
                    "role",
                    "content"
                ],
                "title": "MessageOut"
            },
            "RegisterRequest": {
                "properties": {
                    "email": {
                        "type": "string",
                        "minLength": 3,
                        "title": "Email"
                    },
                    "password": {
                        "type": "string",
                        "minLength": 6,
                        "title": "Password"
                    },
                    "name": {
                        "type": "string",
                        "title": "Name",
                        "default": ""
                    }
                },
                "type": "object",
                "required": [
                    "email",
                    "password"
                ],
                "title": "RegisterRequest"
            },
            "SessionDetail": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "title": "Id"
                    },
                    "title": {
                        "type": "string",
                        "title": "Title"
                    },
                    "agent_slug": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Agent Slug"
                    },
                    "messages": {
                        "items": {
                            "$ref": "#/components/schemas/MessageOut"
                        },
                        "type": "array",
                        "title": "Messages"
                    }
                },
                "type": "object",
                "required": [
                    "id",
                    "title",
                    "messages"
                ],
                "title": "SessionDetail"
            },
            "SessionSummary": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "title": "Id"
                    },
                    "title": {
                        "type": "string",
                        "title": "Title"
                    },
                    "agent_slug": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Agent Slug"
                    },
                    "updated_at": {
                        "type": "string",
                        "title": "Updated At"
                    }
                },
                "type": "object",
                "required": [
                    "id",
                    "title",
                    "updated_at"
                ],
                "title": "SessionSummary"
            },
            "ShareResponse": {
                "properties": {
                    "token": {
                        "type": "string",
                        "title": "Token"
                    },
                    "url": {
                        "type": "string",
                        "title": "Url"
                    }
                },
                "type": "object",
                "required": [
                    "token",
                    "url"
                ],
                "title": "ShareResponse"
            },
            "UserInfo": {
                "properties": {
                    "user_id": {
                        "type": "integer",
                        "title": "User Id"
                    },
                    "email": {
                        "type": "string",
                        "title": "Email"
                    },
                    "name": {
                        "type": "string",
                        "title": "Name",
                        "default": ""
                    }
                },
                "type": "object",
                "required": [
                    "user_id",
                    "email"
                ],
                "title": "UserInfo"
            },
            "ValidationError": {
                "properties": {
                    "loc": {
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        },
                        "type": "array",
                        "title": "Location"
                    },
                    "msg": {
                        "type": "string",
                        "title": "Message"
                    },
                    "type": {
                        "type": "string",
                        "title": "Error Type"
                    },
                    "input": {
                        "title": "Input"
                    },
                    "ctx": {
                        "type": "object",
                        "title": "Context"
                    }
                },
                "type": "object",
                "required": [
                    "loc",
                    "msg",
                    "type"
                ],
                "title": "ValidationError"
            }
        }
    },
    "servers": [
        {
            "url": "/api/v1"
        }
    ]
}
